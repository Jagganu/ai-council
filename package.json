{
  "name": "ai-council",
  "version": "0.1.0",
  "description": "Multi-agent consensus framework for OpenCode, Cursor, Claude Code, and similar tools",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint --fix packages/*/src/**/*.ts",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ai-council.git"
  },
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "dependencies": {
    "yaml": "^2.3.0",
    "axios": "^1.6.0"
  }
}
